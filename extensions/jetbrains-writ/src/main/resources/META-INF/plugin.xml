<idea-plugin>
    <id>com.writ.plugin</id>
    <name>Writ</name>
    <vendor>writ-lang</vendor>
    <description>Language support for the Writ scripting language — syntax highlighting via TextMate grammar, LSP integration for diagnostics, completions, and navigation.</description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lsp</depends>
    <depends>org.jetbrains.plugins.textmate</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- File type registration -->
        <fileType
            name="Writ"
            implementationClass="com.writ.plugin.WritFileType"
            fieldName="INSTANCE"
            language="Writ"
            extensions="writ"/>

        <!-- Comment toggling (Cmd+/ / Ctrl+/) -->
        <lang.commenter
            language="Writ"
            implementationClass="com.writ.plugin.WritCommenter"/>

        <!-- LSP support via built-in IntelliJ LSP API (2025.3+) -->
        <platform.lsp.serverSupportProvider
            implementation="com.writ.plugin.WritLspServerSupportProvider"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij.textmate">
        <!-- TextMate bundle for syntax highlighting -->
        <bundleProvider implementation="com.writ.plugin.WritTextMateBundleProvider"/>
    </extensions>
</idea-plugin>
