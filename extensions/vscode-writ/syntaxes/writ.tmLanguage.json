{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Writ",
  "scopeName": "source.writ",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#multiline-strings" },
    { "include": "#keywords" },
    { "include": "#storage" },
    { "include": "#modifiers" },
    { "include": "#constants" },
    { "include": "#primitive-types" },
    { "include": "#generic-types" },
    { "include": "#numeric-literals" },
    { "include": "#declarations" },
    { "include": "#function-call" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.writ",
          "match": "//.*$"
        },
        {
          "name": "comment.block.writ",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.writ" } },
          "endCaptures": { "0": { "name": "punctuation.definition.comment.end.writ" } }
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.writ",
          "begin": "\"(?!\"\")",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.writ" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.writ" } },
          "patterns": [
            { "include": "#string-interpolation-block" },
            { "include": "#string-interpolation-simple" },
            { "include": "#string-escape" }
          ]
        }
      ]
    },

    "multiline-strings": {
      "patterns": [
        {
          "name": "string.quoted.triple.writ",
          "begin": "\"\"\"",
          "end": "\"\"\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.writ" } },
          "endCaptures": { "0": { "name": "punctuation.definition.string.end.writ" } },
          "patterns": [
            { "include": "#string-interpolation-block" },
            { "include": "#string-interpolation-simple" },
            { "include": "#string-escape" }
          ]
        }
      ]
    },

    "string-interpolation-block": {
      "name": "meta.interpolation.writ",
      "begin": "\\$\\{",
      "end": "\\}",
      "beginCaptures": { "0": { "name": "punctuation.section.interpolation.begin.writ" } },
      "endCaptures": { "0": { "name": "punctuation.section.interpolation.end.writ" } },
      "patterns": [
        { "include": "source.writ" }
      ]
    },

    "string-interpolation-simple": {
      "match": "(\\$)([a-zA-Z_][a-zA-Z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.definition.interpolation.writ" },
        "2": { "name": "variable.other.interpolation.writ" }
      }
    },

    "string-escape": {
      "name": "constant.character.escape.writ",
      "match": "\\\\[nrt\\\\\"\\$0]"
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.writ",
          "match": "\\b(if|else|when|while|for|in|break|continue|return|start|yield)\\b"
        },
        {
          "name": "keyword.control.import.writ",
          "match": "\\b(import|export|from)\\b"
        },
        {
          "name": "keyword.operator.writ",
          "match": "\\b(is|as)\\b"
        }
      ]
    },

    "storage": {
      "patterns": [
        {
          "name": "storage.type.writ",
          "match": "\\b(class|func|trait|enum|struct|let|var|const)\\b"
        }
      ]
    },

    "modifiers": {
      "patterns": [
        {
          "name": "storage.modifier.writ",
          "match": "\\b(public|private|static|extends|with|set)\\b"
        }
      ]
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.writ",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.writ",
          "match": "\\b(null)\\b"
        },
        {
          "name": "variable.language.self.writ",
          "match": "\\b(self)\\b"
        }
      ]
    },

    "primitive-types": {
      "patterns": [
        {
          "name": "support.type.primitive.writ",
          "match": "\\b(int|float|string|bool|void|bigint|uint|ubigint|bigfloat)\\b"
        }
      ]
    },

    "generic-types": {
      "patterns": [
        {
          "name": "support.type.generic.writ",
          "match": "\\b(Array|Dictionary|Result|Optional|Success|Error)\\b"
        }
      ]
    },

    "numeric-literals": {
      "patterns": [
        {
          "name": "constant.numeric.float.writ",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.writ",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "declarations": {
      "patterns": [
        {
          "match": "\\b(class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.writ" },
            "2": { "name": "entity.name.type.class.writ" }
          }
        },
        {
          "match": "\\b(trait)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.writ" },
            "2": { "name": "entity.name.type.trait.writ" }
          }
        },
        {
          "match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.writ" },
            "2": { "name": "entity.name.type.enum.writ" }
          }
        },
        {
          "match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.writ" },
            "2": { "name": "entity.name.type.struct.writ" }
          }
        },
        {
          "match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
          "captures": {
            "1": { "name": "storage.type.writ" },
            "2": { "name": "entity.name.function.writ" }
          }
        }
      ]
    },

    "function-call": {
      "patterns": [
        {
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.call.writ" }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.spread.writ",
          "match": "\\.\\.\\."
        },
        {
          "name": "keyword.operator.range.inclusive.writ",
          "match": "\\.\\.="
        },
        {
          "name": "keyword.operator.fat-arrow.writ",
          "match": "=>"
        },
        {
          "name": "keyword.operator.arrow.writ",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.writ",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.assignment.writ",
          "match": "\\+=|-=|\\*=|/=|%="
        },
        {
          "name": "keyword.operator.logical.writ",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.null-coalescing.writ",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.safe-access.writ",
          "match": "\\?\\."
        },
        {
          "name": "keyword.operator.error-propagation.writ",
          "match": "\\?"
        },
        {
          "name": "keyword.operator.namespace.writ",
          "match": "::"
        },
        {
          "name": "keyword.operator.range.writ",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.comparison.writ",
          "match": "<|>"
        },
        {
          "name": "keyword.operator.assignment.writ",
          "match": "="
        },
        {
          "name": "keyword.operator.arithmetic.writ",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.access.writ",
          "match": "\\."
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.braces.begin.writ",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.braces.end.writ",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.writ",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.writ",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.writ",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.writ",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.writ",
          "match": ","
        },
        {
          "name": "punctuation.separator.colon.writ",
          "match": ":"
        },
        {
          "name": "punctuation.terminator.semicolon.writ",
          "match": ";"
        }
      ]
    },

    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.writ",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
